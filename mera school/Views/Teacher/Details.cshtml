@model mera_school.Models.Teacher
@{
    ViewData["Title"] = "Teacher Details";
}

<div class="page-header animate-in">
    <div>
        <h1 class="page-title"><i class="fas fa-id-badge me-2" style="color:var(--secondary)"></i>Teacher Details</h1>
        <div class="page-subtitle">Full profile for @Model.FullName</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-custom" style="background:linear-gradient(135deg,#0ea5e9,#38bdf8);">
            <i class="fas fa-edit"></i> Edit
        </a>
        <a asp-action="Index" class="btn-outline-custom"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row g-4 animate-in delay-1">
    <!-- Profile Card -->
    <div class="col-lg-4">
        <div class="content-card text-center p-4">
            @if (!string.IsNullOrEmpty(Model.TeacherImage))
            {
                <img src="@Model.TeacherImage" alt="@Model.FullName"
                     style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:4px solid #e0f2fe;margin-bottom:16px;" />
            }
            else
            {
                <div style="width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,#0ea5e9,#38bdf8);
                            display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:#fff;
                            margin:0 auto 16px;border:4px solid #e0f2fe;">
                    @Model.FullName.Substring(0,1).ToUpper()
                </div>
            }
            <h4 class="fw-700 mb-1" style="color:#1e293b;">@Model.FullName</h4>
            <span class="mb-2 d-inline-block" style="background:#e0f2fe;color:#0369a1;padding:4px 12px;border-radius:20px;font-size:0.8rem;font-weight:600;">
                @Model.Subject
            </span>
            <div class="text-muted-sm mb-3">@Model.Email</div>
            <div class="fw-700" style="font-size:1.3rem;color:#10b981;">PKR @Model.Salary.ToString("N0")</div>
            <div class="text-muted-sm">Monthly Salary</div>

            <div class="mt-4 pt-3 border-top">
                <div class="row text-center">
                    <div class="col-6">
                        <div class="fw-700" style="font-size:1.4rem;color:var(--secondary);">@Model.Attendances.Count</div>
                        <div class="text-muted-sm">Sessions</div>
                    </div>
                    <div class="col-6">
                        <div class="fw-700" style="font-size:1.4rem;color:var(--primary);">
                            @((DateTime.Today - Model.JoinDate).Days / 365)
                        </div>
                        <div class="text-muted-sm">Years Exp.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Details -->
    <div class="col-lg-8">
        <div class="content-card">
            <div class="content-card-header">
                <div class="content-card-title"><i class="fas fa-info-circle" style="color:var(--secondary)"></i> Teacher Information</div>
            </div>
            <div class="content-card-body">
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-hashtag me-2 text-muted"></i>Teacher ID</div>
                    <div class="detail-value">#@Model.Id</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-user me-2 text-muted"></i>Full Name</div>
                    <div class="detail-value fw-600">@Model.FullName</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-book me-2 text-muted"></i>Subject</div>
                    <div class="detail-value">@Model.Subject</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-graduation-cap me-2 text-muted"></i>Qualification</div>
                    <div class="detail-value">@Model.Qualification</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-envelope me-2 text-muted"></i>Email</div>
                    <div class="detail-value">@Model.Email</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-phone me-2 text-muted"></i>Phone</div>
                    <div class="detail-value">@Model.PhoneNumber</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-money-bill-wave me-2 text-muted"></i>Salary</div>
                    <div class="detail-value fw-600" style="color:#10b981;">PKR @Model.Salary.ToString("N0")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-calendar-alt me-2 text-muted"></i>Join Date</div>
                    <div class="detail-value">@Model.JoinDate.ToString("MMMM dd, yyyy")</div>
                </div>
            </div>
        </div>
    </div>
</div>
