@model IEnumerable<mera_school.Models.Student>
@{
    ViewData["Title"] = "Students";
    int page       = ViewBag.Page       ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int total      = ViewBag.TotalRecords ?? 0;
    string search  = ViewBag.Search    ?? "";
    string sortBy  = ViewBag.SortBy    ?? "name";
    string gender  = ViewBag.Gender    ?? "";
    string cls     = ViewBag.ClassName ?? "";
    var classes    = ViewBag.Classes   as List<string> ?? new List<string>();
}

<!-- Page Header -->
<div class="page-header animate-in">
    <div>
        <h1 class="page-title"><i class="fas fa-user-graduate me-2" style="color:var(--primary)"></i>Students</h1>
        <div class="page-subtitle">Manage all enrolled students – @total record(s) found</div>
    </div>
    <a asp-action="Create" class="btn-primary-custom">
        <i class="fas fa-user-plus"></i> Add Student
    </a>
</div>

<!-- Filter Bar -->
<div class="filter-bar animate-in delay-1">
    <form method="get" asp-action="Index" class="row g-2 align-items-end">
        <div class="col-md-4">
            <div class="search-wrapper">
                <i class="fas fa-search search-icon"></i>
                <input type="text" name="search" value="@search" class="search-input" placeholder="Search by name, email, class…" />
            </div>
        </div>
        <div class="col-md-2">
            <select name="gender" class="form-control-custom">
                <option value="">All Genders</option>
                <option value="Male"   selected="@(gender=="Male"   ? "selected" : null)">Male</option>
                <option value="Female" selected="@(gender=="Female" ? "selected" : null)">Female</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="className" class="form-control-custom">
                <option value="">All Classes</option>
                @foreach (var c in classes)
                {
                    <option value="@c" selected="@(cls == c ? "selected" : null)">@c</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="sortBy" class="form-control-custom">
                <option value="name"  selected="@(sortBy=="name"  ? "selected" : null)">Sort: Name</option>
                <option value="age"   selected="@(sortBy=="age"   ? "selected" : null)">Sort: Age</option>
                <option value="class" selected="@(sortBy=="class" ? "selected" : null)">Sort: Class</option>
                <option value="date"  selected="@(sortBy=="date"  ? "selected" : null)">Sort: Date</option>
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn-primary-custom flex-fill" style="justify-content:center;">
                <i class="fas fa-filter"></i> Filter
            </button>
            <a asp-action="Index" class="btn-outline-custom" style="padding:10px 12px;">
                <i class="fas fa-redo"></i>
            </a>
        </div>
    </form>
</div>

<!-- Table Card -->
<div class="content-card animate-in delay-2">
    <div class="table-responsive">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="fas fa-user-graduate d-block"></i>
                <h5>No students found</h5>
                <p class="text-muted-sm">Try adjusting your search or add a new student.</p>
                <a asp-action="Create" class="btn-primary-custom mt-2 d-inline-flex">
                    <i class="fas fa-plus"></i> Add Student
                </a>
            </div>
        }
        else
        {
            <table class="school-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Student</th>
                        <th>Gender</th>
                        <th>Age</th>
                        <th>Class</th>
                        <th>Phone</th>
                        <th>Admission Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="text-muted-sm fw-600">@s.Id</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(s.StudentImage))
                                    {
                                        <img src="@s.StudentImage" class="table-avatar" alt="@s.FullName" />
                                    }
                                    else
                                    {
                                        <div class="table-avatar-placeholder">@s.FullName.Substring(0,1).ToUpper()</div>
                                    }
                                    <div>
                                        <div class="fw-600">@s.FullName</div>
                                        <div class="text-muted-sm">@s.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (s.Gender == "Male")
                                { <span class="badge-gender-m"><i class="fas fa-mars me-1"></i>Male</span> }
                                else
                                { <span class="badge-gender-f"><i class="fas fa-venus me-1"></i>Female</span> }
                            </td>
                            <td>@s.Age yrs</td>
                            <td><span class="badge-class">@s.ClassName</span></td>
                            <td class="text-muted-sm">@s.PhoneNumber</td>
                            <td class="text-muted-sm">@s.AdmissionDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Details" asp-route-id="@s.Id" class="action-btn view" title="Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@s.Id" class="action-btn edit" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form id="del-s-@s.Id" asp-action="Delete" asp-route-id="@s.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="action-btn delete" title="Delete"
                                                onclick="confirmDelete('del-s-@s.Id')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        string prevDisabled = page == 1 ? "disabled" : "";
        string nextDisabled = page == totalPages ? "disabled" : "";
        <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top">
            <span class="text-muted-sm">Page @(page) of @(totalPages)</span>
            <div class="pagination-custom">
                <a asp-action="Index" asp-route-pageNum="@(page-1)" asp-route-search="@search"
                   asp-route-sortBy="@sortBy" asp-route-gender="@gender" asp-route-className="@cls"
                   class="page-btn @prevDisabled">
                    <i class="fas fa-chevron-left"></i>
                </a>
                @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                {
                    string activeClass = i == page ? "active" : "";
                    <a asp-action="Index" asp-route-pageNum="@i" asp-route-search="@search"
                       asp-route-sortBy="@sortBy" asp-route-gender="@gender" asp-route-className="@cls"
                       class="page-btn @activeClass">@i</a>
                }
                <a asp-action="Index" asp-route-pageNum="@(page+1)" asp-route-search="@search"
                   asp-route-sortBy="@sortBy" asp-route-gender="@gender" asp-route-className="@cls"
                   class="page-btn @nextDisabled">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        </div>
    }
</div>
