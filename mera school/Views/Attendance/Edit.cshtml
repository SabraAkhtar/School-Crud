@model mera_school.Models.Attendance
@{
    ViewData["Title"] = "Edit Attendance";
}

<div class="page-header animate-in">
    <div>
        <h1 class="page-title"><i class="fas fa-calendar-edit me-2" style="color:var(--warning)"></i>Edit Attendance</h1>
        <div class="page-subtitle">Update attendance record #@Model.Id</div>
    </div>
    <a asp-action="Index" class="btn-outline-custom" style="border-color:#10b981;color:#10b981;">
        <i class="fas fa-arrow-left"></i> Back to List
    </a>
</div>

<div class="row justify-content-center animate-in delay-1">
    <div class="col-xl-7 col-lg-8">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="form-card">

                <div class="form-section-title" style="color:#10b981;border-color:#d1fae5;">
                    <i class="fas fa-clipboard-check"></i> Attendance Details
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="StudentId" class="form-label-custom">
                            <i class="fas fa-user-graduate" style="color:#10b981;"></i> Student *
                        </label>
                        <select asp-for="StudentId" asp-items="ViewBag.Students" class="form-control-custom">
                            <option value="">-- Select Student --</option>
                        </select>
                        <span asp-validation-for="StudentId" class="text-danger" style="font-size:0.78rem;"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TeacherId" class="form-label-custom">
                            <i class="fas fa-chalkboard-teacher" style="color:#10b981;"></i> Teacher *
                        </label>
                        <select asp-for="TeacherId" asp-items="ViewBag.Teachers" class="form-control-custom">
                            <option value="">-- Select Teacher --</option>
                        </select>
                        <span asp-validation-for="TeacherId" class="text-danger" style="font-size:0.78rem;"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AttendanceDate" class="form-label-custom">
                            <i class="fas fa-calendar-alt" style="color:#10b981;"></i> Date *
                        </label>
                        <input asp-for="AttendanceDate" type="date" class="form-control-custom" />
                        <span asp-validation-for="AttendanceDate" class="text-danger" style="font-size:0.78rem;"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label-custom">
                            <i class="fas fa-toggle-on" style="color:#10b981;"></i> Status *
                        </label>
                        <div class="d-flex gap-2 mt-1">
                            @foreach (var s in new[]{"Present","Absent","Leave"})
                            {
                                <label class="status-radio-label" style="flex:1;cursor:pointer;">
                                    <input type="radio" asp-for="Status" value="@s" class="d-none status-radio" />
                                    <div class="status-radio-btn @s.ToLower()" data-status="@s">
                                        @if (s == "Present") { <i class="fas fa-check me-1"></i> }
                                        else if (s == "Absent") { <i class="fas fa-times me-1"></i> }
                                        else { <i class="fas fa-calendar me-1"></i> }
                                        @s
                                    </div>
                                </label>
                            }
                        </div>
                        <span asp-validation-for="Status" class="text-danger" style="font-size:0.78rem;"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Remarks" class="form-label-custom">
                            <i class="fas fa-comment" style="color:#10b981;"></i> Remarks (Optional)
                        </label>
                        <textarea asp-for="Remarks" class="form-control-custom" rows="3"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-3 justify-content-end pt-2 border-top">
                    <a asp-action="Index" class="btn-outline-custom" style="border-color:#10b981;color:#10b981;">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                    <button type="submit" class="btn-primary-custom" style="background:linear-gradient(135deg,#10b981,#059669);">
                        <i class="fas fa-save"></i> Update Record
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    .status-radio-btn { text-align:center;padding:10px 8px;border-radius:10px;font-size:0.8rem;font-weight:600;border:2px solid #e2e8f0;transition:all 0.2s;background:#f8fafc;color:#64748b; }
    .status-radio-btn.present { border-color:#10b981; }
    .status-radio-btn.absent  { border-color:#ef4444; }
    .status-radio-btn.leave   { border-color:#f59e0b; }
    .status-radio:checked + .status-radio-btn.present { background:#d1fae5;color:#065f46; }
    .status-radio:checked + .status-radio-btn.absent  { background:#fee2e2;color:#991b1b; }
    .status-radio:checked + .status-radio-btn.leave   { background:#fef3c7;color:#92400e; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.querySelectorAll('.status-radio').forEach(radio => {
            if (radio.checked) {
                radio.nextElementSibling.style.boxShadow = '0 4px 12px rgba(0,0,0,0.15)';
            }
            radio.addEventListener('change', () => {
                document.querySelectorAll('.status-radio-btn').forEach(b => b.style.boxShadow = '');
                if (radio.checked) radio.nextElementSibling.style.boxShadow = '0 4px 12px rgba(0,0,0,0.15)';
            });
        });
    </script>
}
