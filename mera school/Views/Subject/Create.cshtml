@model mera_school.Models.Subject
@{
    ViewData["Title"] = "Add Subject";
}

<div class="page-header animate-in">
    <div>
        <h1 class="page-title"><i class="fas fa-plus-circle me-2" style="color:var(--secondary)"></i>Add Subject</h1>
        <div class="page-subtitle">Create a new subject and assign a teacher</div>
    </div>
    <a asp-action="Index" class="btn-outline-custom">
        <i class="fas fa-arrow-left"></i> Back to List
    </a>
</div>

<div class="row animate-in delay-1">
    <div class="col-lg-8 mx-auto">
        <div class="content-card p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="SubjectName" class="form-label fw-600 text-muted-sm"></label>
                    <input asp-for="SubjectName" class="form-control-custom w-100" placeholder="e.g. Mathematics" />
                    <span asp-validation-for="SubjectName" class="text-danger" style="font-size:0.85rem;margin-top:4px;display:block;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SubjectCode" class="form-label fw-600 text-muted-sm"></label>
                    <input asp-for="SubjectCode" class="form-control-custom w-100" placeholder="e.g. MATH-101" />
                    <span asp-validation-for="SubjectCode" class="text-danger" style="font-size:0.85rem;margin-top:4px;display:block;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Credits" class="form-label fw-600 text-muted-sm"></label>
                    <input asp-for="Credits" type="number" class="form-control-custom w-100" placeholder="e.g. 3" />
                    <span asp-validation-for="Credits" class="text-danger" style="font-size:0.85rem;margin-top:4px;display:block;"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="TeacherId" class="form-label fw-600 text-muted-sm"></label>
                    <select asp-for="TeacherId" class="form-control-custom w-100" asp-items="ViewBag.TeacherId">
                        <option value="">-- Select Assigned Teacher --</option>
                    </select>
                    <span asp-validation-for="TeacherId" class="text-danger" style="font-size:0.85rem;margin-top:4px;display:block;"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn-outline-custom">Cancel</a>
                    <button type="submit" class="btn-primary-custom px-4">
                        <i class="fas fa-save me-1"></i> Save Subject
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
