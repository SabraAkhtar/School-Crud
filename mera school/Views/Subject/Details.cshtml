@model mera_school.Models.Subject
@{
    ViewData["Title"] = "Subject Details";
}

<div class="page-header animate-in">
    <div>
        <h1 class="page-title"><i class="fas fa-info-circle me-2" style="color:var(--secondary)"></i>Subject Details</h1>
        <div class="page-subtitle">View information for @Model.SubjectName</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.SubjectId" class="btn-primary-custom">
            <i class="fas fa-edit me-1"></i> Edit
        </a>
        <a asp-action="Index" class="btn-outline-custom">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row animate-in delay-1">
    <div class="col-lg-6 mx-auto">
        <div class="content-card p-4">
            <div class="d-flex align-items-center gap-3 mb-4 pb-3 border-bottom">
                <div class="avatar-lg" style="background:#f3e8ff; color:#7e22ce;">
                    <i class="fas fa-book fa-2x"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold">@Model.SubjectName</h3>
                    <span class="badge-class" style="background:#e0f2fe;color:#0369a1;">Code: @Model.SubjectCode</span>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-sm-6">
                    <div class="text-muted-sm fw-600 mb-1">Credits</div>
                    <div class="fw-bold fs-5">@Model.Credits</div>
                </div>
                <div class="col-sm-6">
                    <div class="text-muted-sm fw-600 mb-1">Assigned Teacher</div>
                    <div class="fw-bold fs-5">
                        @if(Model.Teacher != null)
                        {
                            <a asp-controller="Teacher" asp-action="Details" asp-route-id="@Model.TeacherId" style="text-decoration:none;color:var(--primary);">
                                @Model.Teacher.FullName
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Not Assigned</span>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                <form id="del-s-@Model.SubjectId" asp-action="Delete" asp-route-id="@Model.SubjectId" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-outline-danger" style="border-radius:12px; font-weight:500;"
                            onclick="confirmDelete('del-s-@Model.SubjectId')">
                        <i class="fas fa-trash me-1"></i> Delete Subject
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
