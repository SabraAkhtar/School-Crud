@model IEnumerable<mera_school.Models.Subject>
@{
    ViewData["Title"] = "Subjects";
    int page       = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string search  = ViewBag.CurrentFilter ?? "";
}

<div class="page-header animate-in">
    <div>
        <h1 class="page-title"><i class="fas fa-book me-2" style="color:var(--secondary)"></i>Subjects / Courses</h1>
        <div class="page-subtitle">Manage all school subjects</div>
    </div>
    <a asp-action="Create" class="btn-primary-custom">
        <i class="fas fa-plus-circle"></i> Add Subject
    </a>
</div>

<!-- Filter Bar -->
<div class="filter-bar animate-in delay-1">
    <form method="get" asp-action="Index" class="row g-2 align-items-end">
        <div class="col-md-5">
            <div class="search-wrapper">
                <i class="fas fa-search search-icon"></i>
                <input type="text" name="searchString" value="@search" class="search-input" placeholder="Search by name or code…" />
            </div>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn-primary-custom flex-fill" style="justify-content:center;">
                <i class="fas fa-filter"></i> Filter
            </button>
            <a asp-action="Index" class="btn-outline-custom" style="padding:10px 12px;">
                <i class="fas fa-redo"></i>
            </a>
        </div>
    </form>
</div>

<!-- Table Card -->
<div class="content-card animate-in delay-2">
    <div class="table-responsive">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="fas fa-book d-block"></i>
                <h5>No subjects found</h5>
                <p class="text-muted-sm">Try adjusting your search or add a new subject.</p>
                <a asp-action="Create" class="btn-primary-custom mt-2 d-inline-flex">
                    <i class="fas fa-plus"></i> Add Subject
                </a>
            </div>
        }
        else
        {
            <table class="school-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Subject Name</th>
                        <th>Code</th>
                        <th>Credits</th>
                        <th>Assigned Teacher</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted-sm fw-600">@item.SubjectId</td>
                            <td>
                                <div class="fw-600">@item.SubjectName</div>
                            </td>
                            <td><span class="badge-class" style="background:#f3e8ff;color:#7e22ce;">@item.SubjectCode</span></td>
                            <td class="fw-600 text-muted-sm">@item.Credits</td>
                            <td>
                                @if(item.Teacher != null)
                                {
                                    <span>Teacher @item.Teacher.FullName teaches Subject @item.SubjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not Assigned</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Details" asp-route-id="@item.SubjectId" class="action-btn view" title="Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.SubjectId" class="action-btn edit" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form id="del-s-@item.SubjectId" asp-action="Delete" asp-route-id="@item.SubjectId" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="action-btn delete" title="Delete"
                                                onclick="confirmDelete('del-s-@item.SubjectId')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (totalPages > 1)
    {
        string prevDisabled = page == 1 ? "disabled" : "";
        string nextDisabled = page == totalPages ? "disabled" : "";
        <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top">
            <span class="text-muted-sm">Page @(page) of @(totalPages)</span>
            <div class="pagination-custom">
                <a asp-action="Index" asp-route-pageNumber="@(page-1)" asp-route-searchString="@search"
                   class="page-btn @prevDisabled">
                    <i class="fas fa-chevron-left"></i>
                </a>
                @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                {
                    string activeClass = i == page ? "active" : "";
                    <a asp-action="Index" asp-route-pageNumber="@i" asp-route-searchString="@search"
                       class="page-btn @activeClass">@i</a>
                }
                <a asp-action="Index" asp-route-pageNumber="@(page+1)" asp-route-searchString="@search"
                   class="page-btn @nextDisabled">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        </div>
    }
</div>
