<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Mera School</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- SweetAlert2 -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script>
        tailwind.config = {
            corePlugins: { preflight: false },
            prefix: 'tw-'
        }
    </script>
</head>
<body class="bg-slate-50" style="font-family:'Inter',sans-serif;">

    <!-- ═══════════════════════════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════════════════════════ -->
    <div id="sidebar" class="sidebar">
        <!-- Brand -->
        <div class="sidebar-brand">
            <div class="brand-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <div class="brand-text">
                <span class="brand-name">Mera School</span>
                <span class="brand-sub">Admin Panel</span>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="sidebar-nav">
            <div class="nav-section-label">MAIN MENU</div>

            <a asp-controller="Home" asp-action="Index"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <span class="nav-icon"><i class="fas fa-tachometer-alt"></i></span>
                <span class="nav-label">Dashboard</span>
            </a>

            <a asp-controller="Student" asp-action="Index"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Student" ? "active" : "")">
                <span class="nav-icon"><i class="fas fa-user-graduate"></i></span>
                <span class="nav-label">Students</span>
            </a>

            <a asp-controller="Teacher" asp-action="Index"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Teacher" ? "active" : "")">
                <span class="nav-icon"><i class="fas fa-chalkboard-teacher"></i></span>
                <span class="nav-label">Teachers</span>
            </a>

            <a asp-controller="Subject" asp-action="Index"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Subject" ? "active" : "")">
                <span class="nav-icon"><i class="fas fa-book"></i></span>
                <span class="nav-label">Subjects</span>
            </a>

            <a asp-controller="Attendance" asp-action="Index"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Attendance" ? "active" : "")">
                <span class="nav-icon"><i class="fas fa-clipboard-check"></i></span>
                <span class="nav-label">Attendance</span>
            </a>

            <div class="nav-section-label mt-4">QUICK ADD</div>

            <a asp-controller="Student" asp-action="Create" class="nav-link-item">
                <span class="nav-icon"><i class="fas fa-user-plus"></i></span>
                <span class="nav-label">Add Student</span>
            </a>

            <a asp-controller="Teacher" asp-action="Create" class="nav-link-item">
                <span class="nav-icon"><i class="fas fa-plus-circle"></i></span>
                <span class="nav-label">Add Teacher</span>
            </a>

            <a asp-controller="Subject" asp-action="Create" class="nav-link-item">
                <span class="nav-icon"><i class="fas fa-plus-square"></i></span>
                <span class="nav-label">Add Subject</span>
            </a>

            <a asp-controller="Attendance" asp-action="Create" class="nav-link-item">
                <span class="nav-icon"><i class="fas fa-calendar-plus"></i></span>
                <span class="nav-label">Mark Attendance</span>
            </a>
        </nav>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer">
            <div class="d-flex align-items-center gap-2">
                <div class="avatar-sm">
                    <i class="fas fa-user-shield"></i>
                </div>
                <div>
                    <div class="fw-600 text-white" style="font-size:0.8rem;">Administrator</div>
                    <div style="font-size:0.7rem;color:#94a3b8;">admin@school.com</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         MAIN CONTENT WRAPPER
    ═══════════════════════════════════════════════════════════ -->
    <div class="main-wrapper">

        <!-- TOP NAVBAR -->
        <header class="top-navbar">
            <div class="d-flex align-items-center gap-3">
                <button id="sidebarToggle" class="sidebar-toggle-btn" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="page-breadcrumb">
                    <span class="breadcrumb-page">@ViewData["Title"]</span>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="navbar-date">
                    <i class="fas fa-calendar-alt me-1"></i>
                    <span id="currentDate"></span>
                </div>
                <div class="navbar-avatar">
                    <i class="fas fa-user-circle fa-lg"></i>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="page-content">

            <!-- Toast Notifications -->
            @if (TempData["Success"] != null)
            {
                <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;">
                    <div class="toast show align-items-center text-white border-0 toast-success" role="alert">
                        <div class="d-flex">
                            <div class="toast-body">
                                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;">
                    <div class="toast show align-items-center text-white border-0 toast-error" role="alert">
                        <div class="d-flex">
                            <div class="toast-body">
                                <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>
                </div>
            }

            @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="page-footer">
            <span>&copy; @DateTime.Now.Year <strong>Mera School</strong> – School Management System</span>
            <span>Built with <i class="fas fa-heart text-danger mx-1"></i> using ASP.NET Core MVC</span>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Live date in navbar
        const d = new Date();
        document.getElementById('currentDate').textContent =
            d.toLocaleDateString('en-US', { weekday:'short', year:'numeric', month:'short', day:'numeric' });

        // Auto-dismiss toasts
        setTimeout(() => {
            document.querySelectorAll('.toast').forEach(t => {
                const bsToast = bootstrap.Toast.getOrCreateInstance(t);
                bsToast.hide();
            });
        }, 4000);

        // Sidebar toggle
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.querySelector('.main-wrapper').classList.toggle('expanded');
        }

        // SweetAlert delete confirmation
        function confirmDelete(formId) {
            Swal.fire({
                title: 'Are you sure?',
                text: 'This action cannot be undone!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: '<i class="fas fa-trash me-1"></i> Yes, Delete',
                cancelButtonText: 'Cancel',
                borderRadius: '16px'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(formId).submit();
                }
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
